generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model administracaomedicacao {
  idadministracaomedicacao Int          @id @default(autoincrement())
  idmedicacao              Int?
  idfuncionario            Int?
  data                     DateTime?    @db.Date
  hora                     DateTime?    @db.Time(6)
  horainfo                 DateTime?    @db.Time(6)
  datahorasysdate          DateTime?    @db.Timestamp(6)
  funcionario              funcionario? @relation(fields: [idfuncionario], references: [idfuncionario], onDelete: NoAction, onUpdate: NoAction, map: "fk_funcionario_idfuncionario")
  medicacao                medicacao?   @relation(fields: [idmedicacao], references: [idmedicacao], onDelete: NoAction, onUpdate: NoAction, map: "fk_medicacao_idmedicacao")
}

model aluno {
  idaluno          Int                @id @default(autoincrement())
  foto             Bytes?
  nome             String?            @db.VarChar(255)
  datanascimento   DateTime?          @db.Date
  matricula        String?            @unique @db.VarChar(50)
  ativo            Boolean?
  datacriacao      DateTime?          @db.Timestamp(6)
  entradasaida     entradasaida[]
  enturmacao       enturmacao[]
  medicacao        medicacao[]
  responsavelaluno responsavelaluno[]
  rotinachecklist  rotinachecklist[]
}

model aviso {
  idaviso            Int                  @id @default(autoincrement())
  idturma            Int?
  idresponsavel      Int?
  dataentrada        DateTime?            @db.Timestamp(6)
  datasaida          DateTime?            @db.Timestamp(6)
  titulo             String?              @db.VarChar(25)
  descricao          String?              @db.VarChar(500)
  datacadastro       DateTime?            @db.Date
  responsavel        responsavel?         @relation(fields: [idresponsavel], references: [idresponsavel], onDelete: NoAction, onUpdate: NoAction, map: "fk_responsavel_idresponsavel")
  turma              turma?               @relation(fields: [idturma], references: [idturma], onDelete: NoAction, onUpdate: NoAction, map: "fk_turma_idturma")
  avisoresponsavel   avisoresponsavel[]
  respostacomunicado respostacomunicado[]
}

model checklist {
  idchecklist     Int               @id @default(autoincrement())
  descricao       String?           @db.VarChar(50)
  ativo           Boolean?
  rotinachecklist rotinachecklist[]
}

model entradasaida {
  identradasaida Int          @id @default(autoincrement())
  idfuncionario  Int?
  idaluno        Int?
  idresponsavel  Int?
  descricao      String?      @db.VarChar(50)
  datahorasys    DateTime?    @db.Timestamp(6)
  aluno          aluno?       @relation(fields: [idaluno], references: [idaluno], onDelete: NoAction, onUpdate: NoAction, map: "fk_aluno_idaluno")
  funcionario    funcionario? @relation(fields: [idfuncionario], references: [idfuncionario], onDelete: NoAction, onUpdate: NoAction, map: "fk_funcionario_idfuncionario")
  responsavel    responsavel? @relation(fields: [idresponsavel], references: [idresponsavel], onDelete: NoAction, onUpdate: NoAction, map: "fk_responsavel_idresponsavel")
}

model enturmacao {
  idaluno     Int
  idturma     Int
  dtmatricula DateTime? @db.Date
  aluno       aluno     @relation(fields: [idaluno], references: [idaluno], onDelete: NoAction, onUpdate: NoAction, map: "fk_aluno_idaluno")
  turma       turma     @relation(fields: [idturma], references: [idturma], onDelete: NoAction, onUpdate: NoAction, map: "fk_turma_idturma")

  @@id([idaluno, idturma], map: "pk_enturmacao")
}

model funcaofuncionario {
  idfuncao        Int           @id @default(autoincrement())
  descricaofuncao String?       @db.VarChar(50)
  funcionario     funcionario[]
}

model funcionario {
  idfuncionario          Int                      @id @default(autoincrement())
  matriculafuncionario   String?                  @db.VarChar(50)
  nome                   String?                  @db.VarChar(255)
  cpf                    String?                  @db.VarChar(50)
  datanascimento         DateTime?                @db.Date
  dataadmissao           DateTime?                @db.Date
  idfuncao               Int?
  ativo                  Boolean?
  email                  String?                  @db.VarChar(100)
  senha                  String?                  @db.VarChar(255)
  foto                   Bytes?
  idinstituicao          Int?
  administracaomedicacao administracaomedicacao[]
  entradasaida           entradasaida[]
  instituicao            instituicao?             @relation(fields: [idinstituicao], references: [idinstituicao], onDelete: NoAction, onUpdate: NoAction, map: "fk_funcionario_instituicao")
  funcaofuncionario      funcaofuncionario?       @relation(fields: [idfuncao], references: [idfuncao], onDelete: NoAction, onUpdate: NoAction, map: "fk_funcionario_funcao")
  rotinachecklist        rotinachecklist[]
  turma                  turma[]
  logsistema             logsistema[]

  @@unique([matriculafuncionario, cpf])
}

model instituicao {
  idinstituicao Int           @id @default(autoincrement())
  descricao     String?       @db.VarChar(255)
  ativo         Boolean?
  dataini       DateTime?     @db.Date
  datafim       DateTime?     @db.Date
  datacriacao   DateTime?     @db.Timestamp(6)
  funcionario   funcionario[]
  turma         turma[]
}

model medicacao {
  idmedicacao            Int                      @id @default(autoincrement())
  idresponsavel          Int?
  idaluno                Int?
  nome                   String?                  @db.VarChar(255)
  descfrequencia         String?                  @db.VarChar(50)
  dosagem                String?                  @db.VarChar(50)
  receita                Bytes?
  dataini                DateTime?                @db.Date
  datafim                DateTime?                @db.Date
  diario                 Boolean?
  semanal                Boolean?
  administracaomedicacao administracaomedicacao[]
  aluno                  aluno?                   @relation(fields: [idaluno], references: [idaluno], onDelete: NoAction, onUpdate: NoAction, map: "fk_aluno_idaluno")
  responsavel            responsavel?             @relation(fields: [idresponsavel], references: [idresponsavel], onDelete: NoAction, onUpdate: NoAction, map: "fk_responsavel_idresponsavel")
}

model responsavel {
  idresponsavel      Int                  @id @default(autoincrement())
  nome               String?              @db.VarChar(255)
  cpf                String?              @db.VarChar(11)
  senha              String?              @db.VarChar(255)
  foto               Bytes?
  celular            String?              @db.VarChar(20)
  descricaotipo      String?              @db.VarChar(50)
  ativo              Boolean?
  datacadastro       DateTime?            @db.Timestamp(6)
  email              String?              @db.VarChar(255)
  master             Boolean?
  aviso              aviso[]
  entradasaida       entradasaida[]
  medicacao          medicacao[]
  responsavelaluno   responsavelaluno[]
  avisoresponsavel   avisoresponsavel[]
  respostacomunicado respostacomunicado[]

  @@unique([cpf, celular])
}

model responsavelaluno {
  idresponsavel Int
  idaluno       Int
  aluno         aluno       @relation(fields: [idaluno], references: [idaluno], onDelete: NoAction, onUpdate: NoAction, map: "fk_aluno_idaluno")
  responsavel   responsavel @relation(fields: [idresponsavel], references: [idresponsavel], onDelete: NoAction, onUpdate: NoAction, map: "fk_responsavel_idresponsavel")

  @@id([idresponsavel, idaluno])
}

model rotinachecklist {
  idchecklist       Int?
  idaluno           Int?
  idfuncionario     Int?
  datahorasys       DateTime?    @db.Timestamp(6)
  rotinafeita       Boolean?
  obsden_o          String?      @map("obsdenÃ£o") @db.VarChar(255)
  idrotinachecklist Int          @id @default(autoincrement())
  aluno             aluno?       @relation(fields: [idaluno], references: [idaluno], onDelete: NoAction, onUpdate: NoAction, map: "fk_aluno_idaluno")
  checklist         checklist?   @relation(fields: [idchecklist], references: [idchecklist], onDelete: NoAction, onUpdate: NoAction, map: "fk_checklist_idchecklist")
  funcionario       funcionario? @relation(fields: [idfuncionario], references: [idfuncionario], onDelete: NoAction, onUpdate: NoAction, map: "fk_funcionario_idfuncionario")
}

model turma {
  idturma          Int          @id @default(autoincrement())
  capacidademaxima Int?
  codigoturma      String?      @unique @db.VarChar(50)
  horaini          DateTime?    @db.Time(6)
  horafim          DateTime?    @db.Time(6)
  dataini          DateTime?    @db.Date
  datafim          DateTime?    @db.Date
  idinstituicao    Int?
  idfuncionario    Int?
  aviso            aviso[]
  enturmacao       enturmacao[]
  funcionario      funcionario? @relation(fields: [idfuncionario], references: [idfuncionario], onDelete: NoAction, onUpdate: NoAction, map: "fk_funcionario_idfuncionario")
  instituicao      instituicao? @relation(fields: [idinstituicao], references: [idinstituicao], onDelete: NoAction, onUpdate: NoAction, map: "fk_instituicao_idinstituicao")
}

model avisoresponsavel {
  idaviso       Int
  idresponsavel Int
  aviso         aviso       @relation(fields: [idaviso], references: [idaviso], onDelete: Cascade)
  responsavel   responsavel @relation(fields: [idresponsavel], references: [idresponsavel], onDelete: Cascade)

  @@id([idaviso, idresponsavel])
}

model respostacomunicado {
  idrespostacomunicado Int         @id @default(autoincrement())
  idaviso              Int
  idresponsavel        Int
  mensagem             String      @db.VarChar(500)
  datahorasysdate      DateTime?   @default(now()) @db.Timestamp(6)
  aviso                aviso       @relation(fields: [idaviso], references: [idaviso], onDelete: Cascade)
  responsavel          responsavel @relation(fields: [idresponsavel], references: [idresponsavel], onDelete: Cascade)
}

model logsistema {
  idlog           Int          @id @default(autoincrement())
  acao            String       @db.VarChar(100)
  entidade        String       @db.VarChar(100)
  identidade      Int?
  detalhes        String?      @db.Text
  ip              String?      @db.VarChar(45)
  datahorasysdate DateTime?    @default(now()) @db.Timestamp(6)
  idfuncionario   Int?
  funcionario     funcionario? @relation(fields: [idfuncionario], references: [idfuncionario], onDelete: SetNull)
}
